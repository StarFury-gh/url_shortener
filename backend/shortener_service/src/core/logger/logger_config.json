{
    "version": 1,
    "disable_existing_loggers": false,
  
    "formatters": {
      "default": {
        "format": "%(levelname)s:    %(asctime)s - %(name)s - %(message)s"
      }
    },
  
    "handlers": {
      "console": {
        "class": "logging.StreamHandler",
        "level": "INFO",
        "formatter": "default",
        "stream": "ext://sys.stdout"
      }
    },
  
    "loggers": {
      "": {
        "level": "DEBUG",
        "handlers": ["console"]
      }
    }
  }